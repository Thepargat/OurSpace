rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile Photos ──────────────────────────────────────────────────────
    // Only the owner can write their own profile; any signed-in user can read
    match /users/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Household Content (Memory Wall, Receipts, etc.) ─────────────────────
    // Any authenticated user can read; any authenticated user can write
    // (We rely on Firestore rules for membership checks — Storage has no joins)
    match /households/{householdId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024; // max 25 MB
    }

    // ── Shared Assets (app icons, etc.) ────────────────────────────────────
    match /assets/{allPaths=**} {
      allow read: if true;  // Public assets
      allow write: if false; // Only via Firebase Console
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
