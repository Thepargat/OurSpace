rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared Household Assets
    match /households/{householdId}/{allPaths=**} {
      // Allow read/write for any authenticated user
      // We rely on Firestore security to ensure householdId integrity in the app,
      // but here we ensure at least some level of isolation.
      allow read, write: if request.auth != null;
    }
    
    // Explicit rule for Memories to ensure no path confusion
    match /households/{householdId}/memories/{filename} {
      allow read, write: if request.auth != null;
    }
  }
}
