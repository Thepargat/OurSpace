rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isHouseholdMember(householdId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/households/$(householdId)) &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidHousehold(data) {
      return data.id is string &&
             data.memberIds is list &&
             data.createdBy is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      // Google Calendar Tokens - strictly private to the user
      match /googleCalendarToken/{document} {
        allow read, write: if isOwner(userId);
      }
    }

    // Invite codes — any authenticated user can read
    match /inviteCodes/{code} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /emailInvites/{inviteId} {
      allow read: if isAuthenticated() && request.auth.token.email == resource.data.email;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    function isJoiningHousehold() {
      return isAuthenticated() &&
             request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
             request.auth.uid in request.resource.data.memberIds &&
             !(request.auth.uid in resource.data.memberIds);
    }

    // Households — only members can read or write
    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if isAuthenticated() && isValidHousehold(request.resource.data);
      allow update: if (isHouseholdMember(householdId) && isValidHousehold(request.resource.data)) || isJoiningHousehold();

      // Everything inside a household
      match /{allSubcollections=**} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // Relationship Insights
      match /insights/latest {
        allow read, write: if isHouseholdMember(householdId);
      }

      // Proactive Alerts
      match /proactiveAlerts/{alertId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // Savings Goals
      match /savingsGoals/{goalId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      // Moods
      match /moods/{moodId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }
  }
}
